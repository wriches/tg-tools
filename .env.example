# Copy to .env and fill in. Get api_id / api_hash from https://my.telegram.org -> API development tools
TG_API_ID=
TG_API_HASH=

# Secret used to encrypt your stored Telegram session at rest.
# Use a long random string. If you change it, you'll have to log in again.
TG_SECRET_KEY=change-me-to-a-long-random-string

# Where to store the local SQLite DB (holds the encrypted session).
TG_DB_PATH=data/tg_tools.db

# Web server bind. Keep on localhost unless you know what you're doing.
TG_HOST=127.0.0.1
TG_PORT=8000
